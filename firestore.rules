rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Explicitly allow public reading of core storefront data
    match /products/{productId} {
      allow read: if true;
    }
    match /posts/{postId} {
      allow read: if true;
    }
    match /coupons/{couponId} {
      allow read: if true;
    }
    
    // Fallback for other documents
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}