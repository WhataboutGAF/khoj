
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Public Collections: Allow anyone to read (get and list)
    // Admin only for write operations
    
    match /products/{productId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /coupons/{couponId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /posts/{postId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Admin Roles: Only signed-in users can access their own role record
    match /roles_admin/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Global recursive read fallback for public collections
    match /{path=**}/products/{doc} { allow read: if true; }
    match /{path=**}/posts/{doc} { allow read: if true; }
    match /{path=**}/coupons/{doc} { allow read: if true; }
  }
}
