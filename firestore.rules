
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Products: Publicly readable (list and get), admin writeable
    match /products/{productId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    // Coupons: Publicly readable (required for checkout validation), admin writeable
    match /coupons/{couponId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Posts (Journal): Publicly readable, admin writeable
    match /posts/{postId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Admin Roles: Only signed-in users can access their own role record
    match /roles_admin/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Allow recursive read for all subcollections under these main entities
    match /{path=**}/products/{doc} { allow read: if true; }
    match /{path=**}/posts/{doc} { allow read: if true; }
    match /{path=**}/coupons/{doc} { allow read: if true; }
  }
}
