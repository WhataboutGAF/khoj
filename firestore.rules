rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Products: Anyone can read, only signed-in admins can write
    match /products/{productId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Posts: Anyone can read, only signed-in admins can write
    match /posts/{postId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Coupons: Anyone can read (for checkout), only signed-in admins can write
    match /coupons/{couponId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Admin Roles: Only signed-in users can access their own role record
    match /roles_admin/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }
  }
}