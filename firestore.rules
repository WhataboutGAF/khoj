rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Public collections for browsing
    // We use allow read (which includes get and list)
    match /products/{productId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /coupons/{couponId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /posts/{postId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Admin Roles
    match /roles_admin/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Recursive wildcards to ensure collection-level queries are allowed
    match /{path=**}/products/{doc} { allow read: if true; }
    match /{path=**}/posts/{doc} { allow read: if true; }
    match /{path=**}/coupons/{doc} { allow read: if true; }
  }
}