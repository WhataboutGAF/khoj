
{
  "entities": {
    "Product": {
      "title": "Product",
      "type": "object",
      "description": "Represents a single product available for purchase.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "basePrice": { "type": "number" },
        "imageUrls": { "type": "array", "items": { "type": "string" } },
        "isVisible": { "type": "boolean" },
        "availableSizes": { "type": "array", "items": { "type": "string" } },
        "collectionId": { "type": "string" }
      },
      "required": ["id", "name", "description", "basePrice", "imageUrls", "isVisible", "availableSizes", "collectionId"]
    },
    "Post": {
      "title": "Post",
      "type": "object",
      "description": "A journal entry or blog post.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "excerpt": { "type": "string" },
        "content": { "type": "string" },
        "coverImage": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "published": { "type": "boolean" },
        "metaTitle": { "type": "string" },
        "metaDescription": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "slug", "content", "published"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/roles_admin/{userId}",
        "definition": {
          "entityName": "AdminRole",
          "description": "Stores admin UIDs."
        }
      },
      {
        "path": "/posts/{postId}",
        "definition": {
          "entityName": "Post",
          "description": "Journal posts collection."
        }
      }
    ]
  }
}
